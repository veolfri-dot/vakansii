# PostgreSQL (Docker: postgresql+asyncpg://jobs:jobs_password@db:5432/jobs_db)
DB_URL=postgresql+asyncpg://jobs:jobs_password@db:5432/jobs_db

# OpenRouter (openrouter.ai -> Keys -> Create Key, добавить $1 кредита)
OPENROUTER_API_KEY=sk-or-v1-...

# Telegram Bot (@BotFather)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Telegram Userbot для парсинга каналов (my.telegram.org)
API_ID=123456
API_HASH=your-api-hash
TELETHON_SESSION_STRING=...

# SuperJob Partner API (api.superjob.ru)
SUPERJOB_SECRET_KEY=your-superjob-key

# Adzuna (developer.adzuna.com)
ADZUNA_APP_ID=your-adzuna-id
ADZUNA_APP_KEY=your-adzuna-key
ADZUNA_COUNTRIES=gb,us,de,ru

# Redis (Upstash free tier или redis://redis:6379 для Docker)
REDIS_URL=redis://redis:6379

# Веб-приложение (для локального теста используйте ngrok: ngrok http 80)
WEBAPP_URL=https://your-ngrok-or-vercel-url.com

# Опционально: API ключ для курсов валют (exchangerate-api.com, бесплатный tier)
EXCHANGE_RATE_API_KEY=your-exchange-rate-key

# Опционально: Ngrok для локального тестирования WebApp
NGROK_AUTHTOKEN=your-ngrok-token
